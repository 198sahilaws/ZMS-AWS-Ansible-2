# Normalize line endings. The control node is Linux: shell scripts and YAML
# committed from a Windows checkout must arrive as LF, or reconverge.sh /
# notify-result.sh fail with "bad interpreter" and YAML tooling can choke.
# Store everything text as LF in the repo regardless of the committer's OS.
* text=auto eol=lf

# Belt-and-suspenders for the files that must be LF at runtime.
*.sh    text eol=lf
*.yml   text eol=lf
*.yaml  text eol=lf
*.cfg   text eol=lf
*.env   text eol=lf
*.service text eol=lf
*.timer   text eol=lf

# Treat binaries as binary (never normalized/diffed).
*.pdf binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
